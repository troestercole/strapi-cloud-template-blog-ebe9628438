{
  "kind": "collectionType",
  "collectionName": "library_updates",
  "info": {
    "singularName": "library-update",
    "pluralName": "library-updates",
    "displayName": "Library Update"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "body": {
      "type": "richtext"
    },
    "date": {
      "type": "date"
    },
    "cta_label": {
      "type": "string"
    },
    "cta_url": {
      "type": "string"
    },
    "pinned": {
      "type": "boolean",
      "default": false
    },
    "archived": {
      "type": "boolean",
      "default": false
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    }
  }
}
