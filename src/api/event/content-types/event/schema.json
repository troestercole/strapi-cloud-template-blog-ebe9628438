{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "Event"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "start": {
      "type": "datetime",
      "required": true
    },
    "end": {
      "type": "datetime"
    },
    "all_day": {
      "type": "boolean",
      "default": false
    },
    "location": {
      "type": "string"
    },
    "category": {
      "type": "enumeration",
      "enum": ["city-meeting", "community", "parks-rec", "holiday", "other"]
    },
    "description": {
      "type": "text"
    },
    "url": {
      "type": "string"
    }
  }
}
